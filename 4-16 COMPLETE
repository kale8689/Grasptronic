// Libraries
#include <Wire.h>
#include "AD5933.h"
#include <LiquidCrystal.h>
#include <math.h>

// MightyZap (Linear Actuator)
#include <ESP32Servo.h>
#include <ESP32RotaryEncoder.h>

//switch settings
#define gen_vout 5
#define gen_vin 17
#define small_vout 4
#define small_vin 16
#define cal_10k 0
#define cal_100 2
#define end 15

//AD5933 Settings
#define START_FREQ   35000      //Start frequency (Hz)
#define FREQ_INCR    1      //Frequency step (Hz)
#define NUM_INCR     1          //Number of increments
#define SETTLING     100        //settling cycles
#define NUM_SWEEPS   10         //number of sweeps
#define TCAADDR 0x70

// Force Software Turn off
const int buttonPin = 23;
//bool forceModeOn = (digitalRead(SWITCH_PIN) == HIGH);
bool autoMode = false;      // tracks which mode you're in
int lastButtonState = LOW;  // remembers previous reading

// ACS725 Current Sensor Seetings
double voltage = 0;
double current = 0;
double raw = 0;
double vZero = 1.565; // Modify this value for ACS725 calibration
// for first pcb vZero = 1.59
// for second pcb vZero = 1.565
double sensitivity = 0.264;
double sum = 0;
double current_old = 0;

// Rotary Pin and Motor Pin Outputs
Servo myServo;
int CLK = 18;
int DT = 19;
int motor_pin = 14;
RotaryEncoder encoder(CLK, DT);

// 900 - 2100 full extention
const int MIN_PULSE = 1100; // extend longer (1270 - original)
const int MAX_PULSE = 1250; // extend shorter (1200 - original)
const int MIN_POS = -40;
const int MAX_POS = 20; // rotary pin 0-20
int encoderValue = 0;

// FORCE MEASUREMENT SETTINGS
const double Kf = 0.11;
const double b = -10.576;
double force = 0;

// Timing for 0.1s sampling
unsigned long lastSample = 0;
const unsigned long sampleInterval = 400; // 100 ms

//LCD pins
LiquidCrystal lcd(26, 27, 32, 33, 12, 13);
AD5933 ad5933;

//STORED CALIBRATION DATA
double gainFactor_general = 0.0;
double gainFactor_small = 0.0;
double systemPhase_general[NUM_INCR+1];
double systemPhase_small[NUM_INCR+1];

// Active calibration pointers
double* activePhase;
double activeGain;
bool calibrated = false;  // Flag to track calibration

// MATERIAL CURRENT LIMIT
String activeMaterial = "";
bool overCurrentTrip = false;  

// function that tells motor to move when rotary pin knob moves
void onTurned(int value) {
  if (value < MIN_POS) value = MIN_POS;
  if (value > MAX_POS) value = MAX_POS;
  // if current over the threshold then knob stops
  if (overCurrentTrip) return;
  encoderValue = constrain(value, MIN_POS, MAX_POS);
  int pulse = map(encoderValue, MIN_POS, MAX_POS, MIN_PULSE, MAX_PULSE);
  myServo.writeMicroseconds(pulse);
}

//Adjusting force function
void adjustingForce() {
      //Current Limits Based on Material
    double limit;
    if (activeMaterial == "Needle") {
      limit = 224.56;
    }
    else if (activeMaterial == "Soaked Mesh") {
      limit = 219.83;
    }
    else if (activeMaterial == "Tissue") {
      limit = 213.38;
    }
    else if (activeMaterial == "Dry Mesh/Suture") {
      limit = 224.56;
    }
    else {
      limit = 9999; // safe default for No Contact
    }

    int pulse = map(encoderValue, MIN_POS, MAX_POS, MIN_PULSE, MAX_PULSE);
    if (current_old > limit) {
      overCurrentTrip = true;
      myServo.writeMicroseconds(pulse - 25); // moves back 25 PWM
      delay(500);
      overCurrentTrip = false;
    } else {
      overCurrentTrip = false;
      myServo.writeMicroseconds(pulse);
    }
}

void tcaselect(uint8_t i) {
  if (i > 7) return;
  Wire.beginTransmission(TCAADDR);
  Wire.write(1 << i);
  Wire.endTransmission();
}

void resetSwitches() {
  digitalWrite(gen_vout,HIGH);
  digitalWrite(gen_vin,HIGH);
  digitalWrite(small_vout,HIGH);
  digitalWrite(small_vin,HIGH);
  digitalWrite(cal_10k,HIGH);
  digitalWrite(cal_100,HIGH);
  digitalWrite(end,HIGH);
}

void initAD5933() {
  if (!(ad5933.reset() &&
        ad5933.setInternalClock(true) &&
        ad5933.setPGAGain(PGA_GAIN_X1) &&
        ad5933.setStartFrequency(START_FREQ) &&
        ad5933.setIncrementFrequency(FREQ_INCR) &&
        ad5933.setNumberIncrements(NUM_INCR) &&
        ad5933.setSettlingCycles(SETTLING))) {
    lcd.print("AD5933 Init Failed!");
    while(1);
  }
  delay(500);
}

void calibrateGeneralRange() {
  //Serial.println("Calibrating General Range...");
  resetSwitches();
  tcaselect(5);
  digitalWrite(cal_10k,LOW);
  digitalWrite(end,LOW);
  digitalWrite(gen_vout,LOW);
  digitalWrite(gen_vin,LOW);
  delay (50);
  initAD5933();
  calculateCalibration(10000, gainFactor_general, systemPhase_general);
  digitalWrite(cal_10k,HIGH);
  digitalWrite(end,HIGH);
}

void calibrateSmallRange() {
  //Serial.println("Calibrating Small Range...");
  resetSwitches();
  tcaselect(7);
  digitalWrite(cal_100,LOW);
  digitalWrite(end,LOW);
  digitalWrite(small_vout,LOW);
  digitalWrite(small_vin,LOW);
  delay(50);
  initAD5933();
  calculateCalibration(100, gainFactor_small, systemPhase_small);
  digitalWrite(cal_100,HIGH);
  digitalWrite(end,HIGH);
}

void calculateCalibration(int calResistor,
                          double &gainOut,
                          double phaseOut[]) {
  int realCode[NUM_INCR+1];
  int imagCode[NUM_INCR+1];
  ad5933.frequencySweep(realCode, imagCode, NUM_INCR+1);
  double magSum = 0.0;
  for (int i = 0; i <= NUM_INCR; i++) {
    double Re = realCode[i];
    double Im = imagCode[i];
    double mag = sqrt(Re*Re + Im*Im);
    magSum += mag;
    phaseOut[i] = atan2(Im, Re);
  }

  double avgMag = magSum / (NUM_INCR+1);
  gainOut = 1.0 / (avgMag * calResistor);

  //Serial.print("Stored Gain Factor: ");
  //Serial.println(gainOut, 12);
}

void switchToGeneralHardware() {
  resetSwitches();
  tcaselect(5);
  initAD5933();
  digitalWrite(end,LOW);
  digitalWrite(gen_vout,LOW);
  digitalWrite(gen_vin,LOW);
}

void switchToSmallHardware() {
  resetSwitches();
  tcaselect(7);
  initAD5933();
  digitalWrite(end,LOW);
  digitalWrite(small_vout,LOW);
  digitalWrite(small_vin,LOW);
}

double measureUnknownImpedance() {
  int realCode[NUM_INCR+1];
  int imagCode[NUM_INCR+1];
  double Z_accum[NUM_INCR+1] = {0};
  double phase_accum[NUM_INCR+1] = {0};
  // -------- MULTIPLE SWEEPS --------
  for (int sweep = 0; sweep < NUM_SWEEPS; sweep++) {
    if (!ad5933.frequencySweep(realCode, imagCode, NUM_INCR+1)) {
      lcd.print("Sweep failed!");
      return 0;
    }
    for (int i = 0; i <= NUM_INCR; i++) {
      double Re = realCode[i];
      double Im = imagCode[i];
      double magCode = sqrt(Re*Re + Im*Im);
      double Z = 1.0 / (magCode * activeGain);
      double rawPhase = atan2(Im, Re);
      double correctedPhase = rawPhase - activePhase[i];
      // Normalize phase to [-PI, PI]
      if (correctedPhase > PI) correctedPhase -= 2*PI;
      if (correctedPhase < -PI) correctedPhase += 2*PI;
      Z_accum[i] += Z;
      phase_accum[i] += correctedPhase;
    }
    delay(20); // small delay between sweeps
  }


  // -------- OUTPUT AVERAGED RESULTS --------
  //Serial.println("Freq(Hz), |Z|(Ohm), Phase(deg)");
  double sumZ = 0.0;
  for (int i = 0; i <= NUM_INCR; i++) {
    double freq = START_FREQ + i * FREQ_INCR;
    double Z_avg = Z_accum[i] / NUM_SWEEPS;
    double phase_avg = (phase_accum[i] / NUM_SWEEPS) * 180.0 / PI;
    sumZ += Z_avg;
    //Serial.print(freq);
    //Serial.print(", ");
    //Serial.print(Z_avg, 2);
    //Serial.print(", ");
    //Serial.println(phase_avg, 2);
  }

  // Return overall average (used for auto-range decision)
  return sumZ / (NUM_INCR+1);
}


void setup() {
  Wire.begin();
  //Serial.begin(115200);
  delay(1000);
  pinMode(buttonPin, INPUT_PULLUP);


  pinMode(gen_vout,OUTPUT);
  pinMode(gen_vin,OUTPUT);
  pinMode(small_vout,OUTPUT);
  pinMode(small_vin,OUTPUT);
  pinMode(cal_10k,OUTPUT);
  pinMode(cal_100,OUTPUT);
  pinMode(end,OUTPUT);

  resetSwitches();

  lcd.begin(20, 4);       // 20 columns, 4 rows
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Beginning calibration...");

  // knows servo is on
  myServo.attach(motor_pin);
  myServo.writeMicroseconds(1250);

  // turns the encoder on
  encoder.setEncoderValue(encoderValue);
  encoder.onTurned(onTurned);
  encoder.setEncoderType(EncoderType::HAS_PULLUP);
  encoder.setBoundaries(MIN_POS, MAX_POS, false);
  encoder.begin();

}


void loop() {
encoder.loop();
  if (!calibrated) {
    calibrateGeneralRange();
    calibrateSmallRange();
    calibrated = true;
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Calibration Complete.");
    delay(5000);
    //lcd.print('Press ENTER to measure sample.');
    return;
  }

  // Measure material
  // Start with general range
  switchToGeneralHardware();
  activeGain = gainFactor_general;
  activePhase = systemPhase_general;

  double avgZ = measureUnknownImpedance();

  if (avgZ < 15000.0) {
    //Serial.println("\nSwitching to Small Range");
    switchToSmallHardware();
    activeGain = gainFactor_small;
    activePhase = systemPhase_small;
    avgZ = measureUnknownImpedance();
  }
  
  // Current Sensor Sampling Averages 50
  unsigned long now = millis();
  if (now - lastSample >= sampleInterval) {
    lastSample = now;
    // ACS725 SAMPLING
    sum = 0;
    for (int i = 0; i < 50; i++) {
      raw = analogRead(25);
      sum += raw;
    }
    sum /= 50;
    voltage = sum * (3.3 / 4095);
    current = fabs((voltage - vZero) / sensitivity) * 1000;
    
    // Force Calculations
        double cappedCurrent = current;
    if (cappedCurrent >= 227.83) {
      cappedCurrent = 227.83; 
    }
    else if (cappedCurrent <= 0) {
      cappedCurrent = 207.83;
    }
    force = Kf*(cappedCurrent-111.68) + b;
    if (force < 0) {
    force = 0;
    }


    //Material Classification
    if (avgZ >= 0.0 && avgZ <= 15.0) {
      activeMaterial = "Needle";
    }
    else if (avgZ >= 15.1 && avgZ <= 50.0) {
      activeMaterial = "Soaked Mesh";
    }
    else if (avgZ >= 50.1 && avgZ <= 120.0) {
      activeMaterial = "Tissue";
    }
    else if (avgZ >= 146000.0 && avgZ <= 150000.0) {
      activeMaterial = "Dry Mesh/Suture";
    }
    else {
      activeMaterial = "No Contact";
    }

    lcd.clear();
    int buttonState = digitalRead(buttonPin);

    // Detect rising edge (LOW → HIGH)
    if (buttonState == HIGH && lastButtonState == LOW) {
        autoMode = !autoMode;   // toggle mode
        delay(50);              // simple debounce
    }
    lastButtonState = buttonState;
    // Adjusting Function
    if (autoMode) {
      adjustingForce();
      lcd.setCursor(0, 3);
      lcd.print("Automatic Mode: "); 
      lcd.print(overCurrentTrip ? "ADJUSTED" : "OK");
    }
    else {
      lcd.setCursor(0, 3);
      lcd.print("Unlimited Mode"); 
    }

    //LCD displays
    lcd.setCursor(0, 0);
    lcd.print(activeMaterial);

    lcd.setCursor(0, 1);
    lcd.print("Impedance: "); 
    lcd.print(avgZ);

    lcd.setCursor(0, 2);
    lcd.print("Current: "); 
    lcd.print(current);
    }
    current_old = current;
    }
   
