// Potentiometer-controlled Stepper Motor with Switch and LEDs
// Pin definitions for Software Prototype
#define blue_LED 12
#define yellow_LED 14
#define red_LED 27               // Red LED illuminate for Unlimited Mode
#define green_LED 26             // Green LED illuminate for AGFM
#define switch_pin 32            // Switch input for proof of concept mode toggling
#define dir_pin 17               // Dir pin for EasyDriver
#define step_pin 16              // Step pin for EasyDriver
#define potPin 34                // Potentiometer input

// Configuration for Software Prototype
const int stepsPerRevolution = 100;  // Corresponds to 1.8 degrees per step
const int maxSteps = 1800;        // Maximum steps from center position
const int deadZone = 200;         // Dead zone around center (reduce if motor doesn't respond at edges)
const int stepDelay = 400;       // Microseconds between steps (speed control)
int currentPos = 0;              // Current motor position
int targetPos = 0;               // Target position from pot
unsigned long lastStepMicros = 0;
const int stepsPerBurst = 50;    // how many steps we attempt per loop
const int minStepDelay = 200;    // clamp if you later speed up

