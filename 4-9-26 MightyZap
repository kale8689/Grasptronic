// ACS725 (Current Sensor)
#include <math.h>
double voltage = 0;
double current = 0;
double raw = 0;
double vZero = 1.50; // Modify this value for ACS725 calibration
double sensitivity = 0.264;
double sum = 0;

// Clock Functions
#include <TimeLib.h>

// MightyZap (Linear Actuator)
#include <ESP32Servo.h>
#include <ESP32RotaryEncoder.h>

Servo myServo;
int CLK = 18;
int DT = 19;
int motor_pin = 14;
RotaryEncoder encoder(CLK, DT);

// 900 - 2100 full extention
const int MIN_PULSE = 1270; // extend longer (1325)
const int MAX_PULSE = 1200; // extend shorter (1175)
const int MIN_POS = 0;
const int MAX_POS = 20; // rotary pin 0-20
int encoderValue = 10;

// CURRENT LIMIT SETTINGS 
const float CURRENT_LIMIT = 30000.0;
bool overCurrentTrip = false;   

// FORCE MEASUREMENT SETTINGS
const double Kf = 0.11;
const double b = -10.576;
double force = 0;

// MATERIAL CURRENT LIMIT
// set with impedance
void setupCurrentLimit() {
  switch (activeMaterial) {
    case sutureNeedle:   current_limit = 224.56; break;
    case drySuture:      current_limit = 219.83; break;
    case salineSuture:   current_limit = 219.83; break;
    case dryMesh:        current_limit = 224.56; break;
    case salineMesh:     current_limit = 216.01; break;
    case tissue:          current_limit = 213.38; break;
  }
}

// function that tells motor to move when rotary pin knob moves
void onTurned(int value) {
  if (value < MIN_POS) value = MIN_POS;
  if (value > MAX_POS) value = MAX_POS;
  // if current over the threshold then knob stops
  if (overCurrentTrip) return;
  encoderValue = constrain(value, MIN_POS, MAX_POS);
  encoderValue = value;
  int pulse = map(encoderValue, MIN_POS, MAX_POS, MIN_PULSE, MAX_PULSE);
  myServo.writeMicroseconds(pulse);
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  // knows servo is on
  myServo.attach(motor_pin);

  // current limit function
  setupCurrentLimit();

  // turns the encoder on
  encoder.onTurned(onTurned);
  encoder.setEncoderType(EncoderType::HAS_PULLUP);
  encoder.setBoundaries(MIN_POS, MAX_POS, false);
  encoder.begin();
}

// Timing for 0.1s sampling
unsigned long lastSample = 0;
const unsigned long sampleInterval = 100; // 100 ms

void loop() {
  // encoder tells MightyZap what to do
  encoder.loop();

  unsigned long now = millis();
  if (now - lastSample >= sampleInterval) {
    lastSample = now;

    // ACS725 SAMPLING
    sum = 0;
    for (int i = 0; i < 50; i++) {
      raw = analogRead(25);
      sum += raw;
    }
    sum /= 50;
    voltage = sum * (3.3 / 4095);
    current = fabs((voltage - vZero) / sensitivity) * 1000;
    double cappedCurrent = current;
    if (cappedCurrent > 227.83) {
      cappedCurrent = 227.83; 
    }
    force = (Kf*cappedCurrent) + b - 111.69;

   // CURRENT LIMIT LOGIC
    if (current > CURRENT_LIMIT) {
      overCurrentTrip = true;
      myServo.writeMicroseconds(0); // This kills the signal to stop the motor
    } else if (current < (CURRENT_LIMIT)) {
      overCurrentTrip = false;
      // Refresh the motor position if not tripped
      int pulse = map(encoderValue, MIN_POS, MAX_POS, MIN_PULSE, MAX_PULSE);
      myServo.writeMicroseconds(pulse);
    }

    
    Serial.print("Current (mA): ");
    Serial.print(current, 3);
    Serial.print(" Encoder Value: ");
    Serial.print(encoderValue);
    Serial.print(" Force Value: "); // this in LCD screen
    Serial.print(encoderValue); // this in LCD screen
    Serial.print(" Force Regulation: "); // this in LCD screen
    Serial.println(overCurrentTrip ? "ADJUSTED" : "OK"); // this in LCD screen
    Serial.print(voltage, 3);
    
  }
}
